{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores rider profile information and statistics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "name": { "type": "string", "description": "Rider's name." },
        "bike": { "type": "string", "description": "Rider's motorcycle model." },
        "mileage": { "type": "string", "description": "Average mileage of the bike." },
        "points": { "type": "integer", "description": "Total points earned." },
        "ridesCount": { "type": "integer", "description": "Total number of rides completed." },
        "totalDistance": { "type": "integer", "description": "Total distance traveled in km." },
        "rank": { "type": "string", "enum": ["Scout", "Pathfinder", "Legend"], "description": "Current rider rank." },
        "memberSince": { "type": "string", "format": "date-time", "description": "When the user joined." }
      },
      "required": ["uid", "name", "bike"]
    },
    "Ride": {
      "title": "Ride",
      "description": "Stores information about a completed ride.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID of the rider." },
        "destination": { "type": "string", "description": "Ride destination name." },
        "distance": { "type": "integer", "description": "Distance in km." },
        "duration": { "type": "string", "description": "Duration of the ride." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the ride was completed." }
      },
      "required": ["uid", "destination", "distance"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Stores motorcycle-related expenses (fuel, maintenance, etc.).",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID of the rider." },
        "type": { "type": "string", "enum": ["Fuel", "Maintenance", "Gear", "Other"], "description": "Type of expense." },
        "amount": { "type": "number", "description": "Amount spent." },
        "date": { "type": "string", "format": "date-time", "description": "When the expense occurred." },
        "note": { "type": "string", "description": "Optional note about the expense." }
      },
      "required": ["uid", "type", "amount", "date"]
    },
    "LiveRide": {
      "title": "Live Ride",
      "description": "Stores real-time location and status of a rider.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UID of the rider." },
        "name": { "type": "string", "description": "Rider's name." },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "status": { "type": "string", "description": "Current status (e.g., 'Riding', 'Stopped')." },
        "destination": { "type": "string", "description": "Current destination." },
        "sharingWith": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs this ride is shared with." },
        "lastUpdated": { "type": "string", "format": "date-time", "description": "Last location update timestamp." }
      },
      "required": ["uid", "name", "location", "status", "lastUpdated"]
    },
    "Friendship": {
      "title": "Friendship",
      "description": "Stores connection between two users.",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" }, "description": "Array of two user UIDs." },
        "status": { "type": "string", "enum": ["pending", "accepted"], "description": "Status of the friendship." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["users", "status"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Individual user profile documents."
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Collection of all completed rides."
    },
    "/expenses/{expenseId}": {
      "schema": "Expense",
      "description": "Collection of all rider expenses."
    },
    "/live_rides/{uid}": {
      "schema": "LiveRide",
      "description": "Real-time ride status for active riders."
    },
    "/friendships/{friendshipId}": {
      "schema": "Friendship",
      "description": "User connections."
    }
  }
}
